# Web UI login username, seeded on first boot.
SWARATELLE_USERNAME=root
# Web UI login password, seeded on first boot; change after first login.
SWARATELLE_PASSWORD=swaratelle
# Optional bearer token for external/API clients.
SWARATELLE_API_TOKEN=replace-this-with-a-long-random-token
# Max concurrent iwaradl downloads.
SWARATELLE_DOWNLOAD_CONCURRENCY=2
# Set true when serving the UI over HTTPS to mark the session cookie Secure.
SWARATELLE_COOKIE_SECURE=false
